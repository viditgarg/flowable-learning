<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:flowable="http://flowable.org/bpmn"
             xmlns:modeler="http://flowable.org/modeler"
             typeLanguage="http://www.w3.org/2001/XMLSchema"
             expressionLanguage="http://www.w3.org/1999/XPath"
             targetNamespace="http://www.flowable.org/processdef"
             exporter="Flowable Open Source Modeler"
             exporterVersion="6.7.2"
             xsi:schemaLocation="
                http://www.omg.org/spec/BPMN/20100524/MODEL
                http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd">

    <process id="case_regV5" name="Case Registration V5" isExecutable="true">

        <!-- START -->
        <startEvent id="startEvent" flowable:initiator="initiator" flowable:formKey="caseregistrationform"
                    flowable:formFieldValidation="true"/>

        <!-- Case Details -->
        <userTask id="caseDetailsTask" name="Validate Case Details"
                  flowable:candidateGroups="stateworkers,managers"
                  flowable:formKey="caseregistrationform" flowable:formFieldValidation="true"/>

        <!-- Search Person -->
        <serviceTask id="searchPersonST" name="Search Person" flowable:async="true"
                     flowable:parallelInSameTransaction="false" flowable:type="http">
            <extensionElements>
                <flowable:field name="requestMethod"><flowable:string>POST</flowable:string></flowable:field>
                <flowable:field name="requestUrl"><flowable:string>http://localhost:9080/case/searchPerson</flowable:string></flowable:field>
                <flowable:field name="requestHeaders"><flowable:string>Content-Type: application/json</flowable:string></flowable:field>
                <flowable:field name="requestBody"><flowable:expression><![CDATA[{
 "firstName":"${firstName}",
 "lastName":"${lastName}",
 "dob":"${dateofbirth}",
 "ssn":"${ssn}",
 "gender":"${gender}"
}]]></flowable:expression></flowable:field>
                <flowable:field name="responseVariableName"><flowable:string>personExist</flowable:string></flowable:field>
                <flowable:field name="saveResponseParameters"><flowable:string>true</flowable:string></flowable:field>
                <flowable:field name="saveResponseVariableAsJson"><flowable:string>false</flowable:string></flowable:field>
            </extensionElements>
        </serviceTask>

        <!-- Parallel Split for SSN & DOCCS -->
        <parallelGateway id="parallelSplit"/>

        <!-- SSN API -->
        <serviceTask id="ssnApiTask" name="SSN Validation API" flowable:async="true"
                     flowable:parallelInSameTransaction="false" flowable:type="http">
            <extensionElements>
                <flowable:field name="requestMethod"><flowable:string>POST</flowable:string></flowable:field>
                <flowable:field name="requestUrl"><flowable:string>http://localhost:9080/case/ssnValidation</flowable:string></flowable:field>
                <flowable:field name="requestHeaders"><flowable:string>Content-Type: application/json</flowable:string></flowable:field>
                <flowable:field name="requestBody"><flowable:expression><![CDATA[{ "ssn":"${ssn}" }]]></flowable:expression></flowable:field>
                <flowable:field name="responseVariableName"><flowable:string>ssnResponse</flowable:string></flowable:field>
                <flowable:field name="saveResponseVariableAsJson"><flowable:string>true</flowable:string></flowable:field>
            </extensionElements>
        </serviceTask>

        <!-- SSN Gateway -->
        <exclusiveGateway id="ssnGateway" default="ssnManualTask"/>
        <userTask id="ssnManualTask" name="SSN Manual Review" flowable:assignee="$INITIATOR"
                  flowable:formKey="detailsvalidationV2" flowable:formFieldValidation="true">
            <extensionElements>
                <modeler:activiti-idm-initiator>true</modeler:activiti-idm-initiator>
            </extensionElements>
        </userTask>

        <!-- DOCCS API -->
        <serviceTask id="doccsApiTask" name="DOCCS Validation API" flowable:delegateExpression="${incarcerationValidationService}">
            <extensionElements>
                <flowable:field name="requestMethod"><flowable:string>POST</flowable:string></flowable:field>
                <flowable:field name="requestUrl"><flowable:string>http://localhost:9080/case/prisonerValidation</flowable:string></flowable:field>
                <flowable:field name="requestHeaders"><flowable:string>Content-Type: application/json</flowable:string></flowable:field>
                <flowable:field name="requestBody"><flowable:expression><![CDATA[{
 "firstName":"${firstName}",
 "lastName":"${lastName}",
 "dob":"${dateofbirth}",
 "ssn":"${ssn}",
 "gender":"${gender}",
 "processInstanceId": "${execution.processInstanceId}"
}]]></flowable:expression></flowable:field>
                <flowable:field name="responseVariableName"><flowable:string>doccsResponse</flowable:string></flowable:field>
                <flowable:field name="saveResponseVariableAsJson"><flowable:string>true</flowable:string></flowable:field>
            </extensionElements>
        </serviceTask>

        <!-- DOCCS Gateway -->
        <exclusiveGateway id="doccsGateway" default="doccsManualTask"/>
        <userTask id="doccsManualTask" name="DOCCS Manual Review" flowable:assignee="$INITIATOR"
                  flowable:formKey="detailsvalidationV2" flowable:formFieldValidation="true">
            <extensionElements>
                <modeler:activiti-idm-initiator>true</modeler:activiti-idm-initiator>
            </extensionElements>
        </userTask>

        <!-- Review Incarceration -->
        <userTask id="reviewIncarcerationTask" name="Review Incarceration"
                  flowable:formKey="reviewIncarcerationForm"
                  flowable:formFieldValidation="true"
                  flowable:assignee="$INITIATOR"/>

        <!-- Exclusive Gateway for status branching -->
        <exclusiveGateway id="reviewIncarcerationGateway" name="Incarceration Status Gateway" />

        <!-- Parallel Join -->
        <inclusiveGateway id="parallelJoin" name="Inclusive Join Gateway" flowable:async="true"/>

        <!-- Address Entry -->
        <userTask id="addressEntryTask" name="Enter Address Details"
                  flowable:formKey="addressForm" flowable:formFieldValidation="true"/>

        <!-- Postal Code SOAP Call -->
        <serviceTask id="postalCodeServiceTask" name="Fetch Postal Code"
                     flowable:delegateExpression="${postalCodeService}"/>

        <!-- Address Review -->
        <userTask id="addressReviewTask" name="Review Address Details"
                  flowable:formKey="addressReviewForm" flowable:formFieldValidation="true"/>

        <!-- Final Review -->
        <userTask id="finalReviewTask" name="Final Validation Review"
                  flowable:candidateGroups="stateworkers,managers"
                  flowable:formKey="detailsvalidationV2" flowable:formFieldValidation="true" flowable:priority="10"/>

        <!-- END -->
        <endEvent id="endEvent"/>

        <!-- SEQUENCE FLOWS -->
        <sequenceFlow id="flow-start-to-caseDetails" sourceRef="startEvent" targetRef="caseDetailsTask"/>
        <sequenceFlow id="flow-caseDetails-to-searchPerson" sourceRef="caseDetailsTask" targetRef="searchPersonST"/>
        <sequenceFlow id="flow-searchPerson-to-parallelSplit" sourceRef="searchPersonST" targetRef="parallelSplit"/>

        <sequenceFlow id="flow-parallelSplit-to-ssn" sourceRef="parallelSplit" targetRef="ssnApiTask"/>
        <sequenceFlow id="flow-parallelSplit-to-doccs" sourceRef="parallelSplit" targetRef="doccsApiTask"/>

        <sequenceFlow id="flow-ssn-to-gateway" sourceRef="ssnApiTask" targetRef="ssnGateway"/>
        <sequenceFlow id="flow-ssnGateway-to-join" sourceRef="ssnGateway" targetRef="parallelJoin">
            <conditionExpression xsi:type="tFormalExpression"><![CDATA[${execution.hasVariable('ssnResponse')}]]></conditionExpression>
        </sequenceFlow>
        <sequenceFlow id="flow-ssnGateway-to-manual" sourceRef="ssnGateway" targetRef="ssnManualTask"/>

        <sequenceFlow id="flow-doccs-to-gateway" sourceRef="doccsApiTask" targetRef="doccsGateway"/>
        <sequenceFlow id="flow-doccsGateway-to-join" sourceRef="doccsGateway" targetRef="parallelJoin">
            <conditionExpression xsi:type="tFormalExpression"><![CDATA[${incarcerationStatus == false}]]></conditionExpression>
        </sequenceFlow>
        <sequenceFlow id="flow-doccsGateway-to-manual" sourceRef="doccsGateway" targetRef="doccsManualTask"/>

        <sequenceFlow id="flow-ssnManual-to-join" sourceRef="ssnManualTask" targetRef="parallelJoin"/>
        <sequenceFlow id="flow-doccsManual-to-review" sourceRef="doccsManualTask" targetRef="reviewIncarcerationTask"/>
        <sequenceFlow id="flow-review-to-gateway" sourceRef="reviewIncarcerationTask" targetRef="reviewIncarcerationGateway"/>

        <sequenceFlow id="flow-to-parallel-if-incarcerated" sourceRef="reviewIncarcerationGateway" targetRef="parallelJoin">
            <conditionExpression xsi:type="tFormalExpression"><![CDATA[${incarcerationStatus == 'Incarcerated'}]]></conditionExpression>
        </sequenceFlow>

        <sequenceFlow id="flow-to-parallel-if-not-incarcerated" sourceRef="reviewIncarcerationGateway" targetRef="parallelJoin">
            <conditionExpression xsi:type="tFormalExpression"><![CDATA[${incarcerationStatus == 'Not Incarcerated'}]]></conditionExpression>
        </sequenceFlow>

        <sequenceFlow id="flow-to-parallel-if-on-parole" sourceRef="reviewIncarcerationGateway" targetRef="parallelJoin">
            <conditionExpression xsi:type="tFormalExpression"><![CDATA[${incarcerationStatus == 'On Parole'}]]></conditionExpression>
        </sequenceFlow>

        <sequenceFlow id="flow-parallelJoin-to-addressEntry" sourceRef="parallelJoin" targetRef="addressEntryTask"/>
        <sequenceFlow id="flow-addressEntry-to-postal" sourceRef="addressEntryTask" targetRef="postalCodeServiceTask"/>
        <sequenceFlow id="flow-postal-to-review" sourceRef="postalCodeServiceTask" targetRef="addressReviewTask"/>
        <sequenceFlow id="flow-review-to-final" sourceRef="addressReviewTask" targetRef="finalReviewTask"/>
        <sequenceFlow id="flow-final-to-end" sourceRef="finalReviewTask" targetRef="endEvent"/>

    </process>
</definitions>