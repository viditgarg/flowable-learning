<?xml version="1.0" encoding="UTF-8"?>

<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             targetNamespace="Examples">

    <process id="approvalProcess" name="Approval Process">

        <startEvent id="start"/>

        <sequenceFlow sourceRef="start" targetRef="submitTask"/>

        <userTask id="submitTask" name="Submitted Application"/>

        <sequenceFlow sourceRef="submitTask" targetRef="managerApproval"/>

        <userTask id="managerApproval" name="Require Manager Approval"/>

        <sequenceFlow sourceRef="managerApproval" targetRef="end"/>

        <endEvent id="end"/>

    </process>

</definitions>
